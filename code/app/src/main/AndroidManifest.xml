<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WaitWell"
        tools:targetApi="31">

        <!-- Splash screen  -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.WaitWell.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Register: shown to first-time users -->
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.WaitWell.Splash" />

        <!-- Main menu screen (Entrant/Admin) -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="false" />

        <!-- Entrant Notification Screen -->
        <activity
            android:name=".EntrantNotificationScreen"
            android:exported="false" />

        <!-- Entrant Chosen Accept Screen -->
        <activity
            android:name=".EntrantChosenAccept"
            android:exported="false" />
        <activity
            android:name=".activities.InvitationResponseActivity"
            android:exported="false" />

        <!-- Entrant Not Chosen Screen -->
        <activity
            android:name=".EntrantNotChosenScreen"
            android:exported="false" />

        <!-- Entrant Notification Options Screen -->
        <activity
            android:name=".EntrantNotificationOptions"
            android:exported="false" />
        <!-- Entrant Event Detail Screen -->
        <activity android:name=".activities.EventDetailActivity"
            android:exported="false" />
        <activity android:name=".activities.ConfirmationActivity"
            android:exported="false" />

        <activity android:name=".activities.WaitListActivity"
            android:exported="false" />
        <activity
            android:name=".activities.EntrantCalendarActivity"
            android:exported="false" />
        <!-- QR Code Scanner (US 01.06.01) -->
        <activity android:name=".activities.QrScanActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <!-- Lock ZXing's scanner to portrait -->
        <activity
            android:name="com.journeyapps.barcodescanner.CaptureActivity"
            android:screenOrientation="portrait"
            tools:replace="screenOrientation" />

        <!-- Organizer-only entry: no Entrant/Admin UI -->
        <activity
            android:name=".activities.OrganizerEntryActivity"
            android:exported="false"
            android:launchMode="singleTop" />
        <!-- Rehaan;s addition for US 02.06.01 : Invited entrants list for organizers -->
        <!-- Rehaan's addition for US 02.06.01 : Invited entrants list for organizers -->
        <activity
            android:name=".activities.InvitedEntrantsActivity"
            android:exported="false" />

<!--Rehaan's addition for US 02.06.02 Cancelled entrants list for organizers -->
        <activity
            android:name=".activities.CancelledEntrantsActivity"
            android:exported="false" />
        <!-- Rehaan's addition for US 02.06.04: Enrolled entrants list, organizer can cancel no-shows -->
        <activity
            android:name=".activities.EnrolledEntrantsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.FinalEntrantsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ViewRequestsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.SamplingConfirmationActivity"
            android:exported="false" />
        <activity
            android:name=".activities.SampledEntrantsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.InviteEntrantsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AllEventsActivity"
            android:exported="false" />

<!--        admin-->
        <activity
            android:name=".activities.AdminMainMenuActivity"
            android:exported="false"/>
        <activity
            android:name=".activities.AdminEventsActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AdminProfilesActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AdminEventRemovedActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AdminProfileRemovedActivity"
            android:exported="false" />




        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.waitwell.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--US 01.02.02: Update Profile Details -->
        <activity android:name=".Profile" />

        <!-- Registration History Screen -->
        <activity
            android:name=".activities.RegistrationHistoryActivity"
            android:exported="false" />

        <activity
            android:name=".activities.OrganizerCommentsActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AdminCommentsActivity"
            android:exported="false" />
        <!-- REHAAN'S ADDITION — US 02.09.01 -->
        <activity
            android:name=".activities.AssignCoOrganizerActivity"
            android:exported="false" />
        <!-- END REHAAN'S ADDITION -->

        <activity
            android:name=".activities.EntrantLotteryCriteria"
            android:exported="false" />

    </application>

</manifest>