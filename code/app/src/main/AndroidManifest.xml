<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WaitWell"
        tools:targetApi="31">

        <!-- Splash screen  -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.WaitWell.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Register: shown to first-time users -->
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.WaitWell.Splash" />

        <!-- Main menu screen -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="false" />
        <!-- Rehaan;s addition for US 02.06.01 : Invited entrants list for organizers -->
        <activity
            android:name=".activities.InvitedEntrantsActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AllEventsActivity"
            android:exported="false" />
    </application>

</manifest>