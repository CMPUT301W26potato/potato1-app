<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- TOP BAR -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_menu_hamburger"/>

        <TextView
            android:layout_centerInParent="true"
            android:layout_height = "wrap_content"
            android:layout_width="wrap_content"
            android:text="Wait Well"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/waitwell_logo"/>
    </RelativeLayout>

    <!-- REMOVED BOX -->
    <TextView
        android:layout_marginTop="20dp"
        android:layout_height = "wrap_content"
        android:layout_width="match_parent"
        android:background="@color/status_closed_text"
        android:text="✔  Profile Removed"
        android:textColor="@color/text_white"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="18sp"
        android:padding="14dp"/>

    <!-- DETAILS -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:paddingEnd="16dp"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_circle_arrow_left"/>

        <TextView
            android:text="User Details"
            android:layout_height = "wrap_content"
            android:layout_width="wrap_content"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/text_primary"/>

    </LinearLayout>
    <ImageView
        android:id="@+id/imgEvent"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="12dp"
        android:scaleType="centerCrop"
        android:src="@drawable/waitwell_logo"/>

    <TextView
        android:id="@+id/txtName"
        android:text="Name:"
        android:layout_height = "wrap_content"
        android:layout_width="wrap_content"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="6dp"/>

    <TextView
        android:id="@+id/txtRole"
        android:text="Role:"
        android:layout_height = "wrap_content"
        android:layout_width="wrap_content"
        android:textColor="@color/text_hint"
        android:textSize="12sp"/>

    <TextView
        android:id="@+id/txtEmail"
        android:text="Email:"
        android:layout_height = "wrap_content"
        android:layout_width="wrap_content"
        android:textColor="@color/text_hint"
        android:textSize="12sp"/>

    <TextView
        android:id="@+id/txtID"
        android:text="ID:"
        android:layout_height = "wrap_content"
        android:layout_width="wrap_content"
        android:textColor="@color/text_hint"
        android:textSize="12sp"/>

    <TextView
        android:id="@+id/txtStatus"
        android:text="Status: Removed"
        android:layout_height = "wrap_content"
        android:layout_width="wrap_content"
        android:textColor="@color/text_hint"
        android:textSize="12sp"/>

    <TextView
        android:id="@+id/txtEventsJoined"
        android:text="Events Joined:"
        android:layout_height = "wrap_content"
        android:layout_width="wrap_content"
        android:textColor="@color/text_hint"
        android:textSize="12sp"/>

</LinearLayout>