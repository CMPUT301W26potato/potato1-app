<?xml version="1.0" encoding="utf-8"?>
<!--
    (Rehaan) Layout for viewing invited (chosen) entrants for an event.
    US 02.06.01
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/bg_white">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_circle_arrow_left"
            android:contentDescription="@string/back" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/no_invited_entrants"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/poppinsmedium"
            android:gravity="center"
            android:layout_marginEnd="32dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />


    <TextView
        android:id="@+id/txtCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:textSize="14sp"
        android:textColor="@color/text_secondary" />


    <TextView
        android:id="@+id/txtLoading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/loading"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:textColor="@color/text_secondary"
        android:textSize="16sp" />


    <TextView
        android:id="@+id/txtEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_invited_entrants"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:textColor="@color/text_hint"
        android:textSize="16sp"
        android:visibility="gone" />


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:contentDescription="@string/invited_entrants_list_desc">

        <LinearLayout
            android:id="@+id/entrantListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />
    </ScrollView>
</LinearLayout>