<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/notification_card_margin">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/leftBorderStrip"
            android:layout_width="@dimen/notification_left_border_width"
            android:layout_height="match_parent"
            android:background="@color/primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/notification_card_inner_padding">

            <FrameLayout
                android:id="@+id/iconContainer"
                android:layout_width="@dimen/notification_icon_container_size"
                android:layout_height="@dimen/notification_icon_container_size"
                android:background="@drawable/bg_waitlist_icon_dark"
                android:contentDescription="@string/notification_type_icon_container_desc">

                <ImageView
                    android:id="@+id/imgNotificationTypeIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/notification_type_icon_desc"
                    android:padding="@dimen/notification_icon_inner_padding"
                    android:scaleType="centerInside"
                    tools:src="@drawable/ic_notifications_selected" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/notification_icon_text_gap"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/categoryTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppinsmedium"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/notification_category_title_text_size"
                    android:textStyle="bold"
                    tools:text="@string/notification_category_invitation" />

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/notification_event_title_margin_top"
                    android:fontFamily="@font/poppinsmedium"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/notification_event_title_text_size"
                    android:textStyle="bold"
                    tools:text="Event title" />

                <TextView
                    android:id="@+id/messageText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/notification_message_margin_top"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/notification_message_text_size"
                    tools:text="Notification body" />

                <TextView
                    android:id="@+id/expiredLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/notification_expired_label_margin_top"
                    android:text="@string/notification_list_expired_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>

            <Button
                android:id="@+id/actionButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/notification_action_button_margin_start" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
