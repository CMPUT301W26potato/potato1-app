<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!--TOP BAR-->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Back arrow -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_circle_arrow_left"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="All Events"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="@font/inter24ptmedium"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/waitwell_logo"
            android:contentDescription="logo" />
    </RelativeLayout>

    <!--SEARCH bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_search_bar"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Search" />

        <EditText
            android:id="@+id/editSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@android:color/transparent"
            android:hint="Search events..."
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />
    </LinearLayout>

    <!-- Filter Chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- "All" chip -->
        <TextView
            android:id="@+id/chipAll"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_filter_active"
            android:gravity="center"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="All"
            android:textColor="@color/text_white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- "Open" chip -->
        <TextView
            android:id="@+id/chipOpen"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_filter_inactive"
            android:gravity="center"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="Open"
            android:textColor="#2E7D32"
            android:textSize="13sp" />

        <!-- Category dropdown chip: "▼ Category" -->
        <TextView
            android:id="@+id/chipCategory"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_filter_dropdown"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="Category ▾"
            android:textColor="#2E7D32"
            android:textSize="13sp" />
    </LinearLayout>

    <!--Active category indicator-->
    <!-- Shows "Showing: Swimming x" when a category is selected -->
    <LinearLayout
        android:id="@+id/categoryIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Showing: "
            android:textColor="@color/text_hint"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtActiveCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#2E7D32"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnClearCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="✕"
            android:textColor="#C62828"
            android:textSize="16sp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- result count-->
    <TextView
        android:id="@+id/txtResultCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingStart="18dp"
        android:text="7 events"
        android:textColor="@color/text_hint"
        android:textSize="13sp" />

    <!-- event list -->
    <ScrollView
        android:id="@+id/scrollEvents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/eventsListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />
    </ScrollView>

    <!-- empty state-->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_search"
            android:alpha="0.3"
            android:contentDescription="No results" />

        <TextView
            android:id="@+id/txtEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="No events match your search"
            android:textColor="@color/text_hint"
            android:textSize="15sp"
            android:gravity="center" />
    </LinearLayout>


    <!--Bottom Nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:background="@color/bg_white"
        app:itemIconTint="@color/text_hint"
        app:itemTextColor="@color/text_hint"
        app:menu="@menu/bottom_nav_menu_main_activity" />

</LinearLayout>
