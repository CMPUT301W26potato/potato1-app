<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/btnViewEntrant"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_waitlist_icon_dark"
            android:contentDescription="@string/waitlist_view_entrant_profile"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_visibility_eye" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtEntrantName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/poppins"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtMatchedValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:fontFamily="@font/inter"
                android:maxLines="1"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnAssignCoOrganizer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_waitlist_icon_green"
            android:contentDescription="@string/co_organizer_assign_button_desc"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_person_add_white" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>