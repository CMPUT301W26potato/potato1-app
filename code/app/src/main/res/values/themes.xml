<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme -->
    <style name="Theme.WaitWell" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary_light</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <!-- Splash screen theme: green status bar, no action bar -->
    <style name="Theme.WaitWell.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/bg_splash_gradient</item>
        <item name="android:statusBarColor">#C8E6C9</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
    </style>
</resources>
